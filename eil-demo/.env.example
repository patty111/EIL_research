# EIL Demo Environment Variables (2-Chain Setup)
# Copy this file to .env and fill in values

# Private key for contract deployment (64 hex chars, no 0x prefix)
# This is Anvil's first default account private key
PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb476c6b8d9c3fedd2301e1e8f547

# Chain RPC URLs
# When running in Docker, use service names:
ARB_RPC=http://anvil-arbitrum:8501
OP_RPC=http://anvil-optimism:8503

# When running locally (outside Docker), use localhost:
# ARB_RPC=http://localhost:8501
# OP_RPC=http://localhost:8503

# Deployment output file (relative to project root)
DEPLOYMENT_FILE=./deployment.json

# EntryPoint deposit amount (in ETH)
EP_DEPOSIT_ETH=0.1

# Optional: Paymaster stake configuration
# PAYMASTER_STAKE=0.5
# PAYMASTER_UNSTAKE_DELAY=86400

# Note: Anvil chains are configured with:
# - Gas limit: 30,000,000 (30M) per block
# - 10 pre-funded test accounts
# - Chain IDs: Arbitrum (42161), Optimism (10)
